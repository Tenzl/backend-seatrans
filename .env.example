SERVER_PORT=8080

# Comma-separated list of allowed frontend origins.
# Required when the frontend sends credentials (cookies) with requests.
# OAuth redirect after Google login uses the first origin in this list.
# Example: http://localhost:3000,https://frontend-seatrans.vercel.app
CORS_ORIGINS=http://localhost:3000,https://frontend-seatrans.vercel.app

DB_URL=postgresql://postgres:secret@localhost:5432/seatrans

# Remote Postgres (e.g. Aiven) requires SSL. Either append ?sslmode=require to DB_URL
# or set DB_SSL=true (DB_SSL_REJECT_UNAUTHORIZED=false for managed CA).
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Fallback DB config (DatabaseModule will use these when DB_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_DATABASE=seatrans

# Leave DB_URL empty to use fallback config above
# DB_URL=

APP_UPLOAD_DIR=./uploads
APP_UPLOAD_INQUIRY_DIR=./uploads/inquiries
APP_UPLOAD_MAX_FILE_SIZE=10485760
APP_UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

APP_JWT_SECRET=super-secret
APP_JWT_EXPIRATION=1d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth2/callback/google
DEFAULT_OAUTH_ROLE=ROLE_CUSTOMER

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=